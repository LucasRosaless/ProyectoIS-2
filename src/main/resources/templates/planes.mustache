<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Gestión de Planes de Estudio</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <div class="container">
        <nav class="nav">
            <a href="/dashboard">← Dashboard</a>
            <a href="/profesores">Profesores</a>
            <a href="/alumnos">Alumnos</a>
            <a href="/carreras">Carreras</a>
            <a href="/planes">Planes</a>
            <a href="/materias">Materias</a>
        </nav>

        <div class="glass-panel">
            <div class="header-flex">
                <h2>Lista de Planes de Estudio</h2>
                <a href="/planes/new" class="btn btn-primary">+ Nuevo Plan</a>
            </div>

            <table>
                <thead>
                    <tr>
                        <th>ID Plan</th>
                        <th>Resolución</th>
                        <th>Año Vigencia</th>
                        <th>Estado</th>
                        <th>ID Carrera</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {{#planes}}
                    <tr>
                        <td>{{id_plan}}</td>
                        <td>{{resolucion}}</td>
                        <td>{{anio_vigencia}}</td>
                        <td>{{estado}}</td>
                        <td>{{id_carrera}}</td>
                        <td class="actions">
                            <a href="/planes/{{id_plan}}/edit" class="btn btn-secondary">Editar</a>
                            <form action="/planes/{{id_plan}}/delete" method="POST" style="display:inline;">
                                <button type="submit" class="btn btn-danger" onclick="return confirm('¿Seguro que desea eliminar?');">Borrar</button>
                            </form>
                        </td>
                    </tr>
                    {{/planes}}
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>
