<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Gestión de Materias</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <div class="container">
        <nav class="nav">
            <a href="/dashboard">← Dashboard</a>
            <a href="/profesores">Profesores</a>
            <a href="/alumnos">Alumnos</a>
            <a href="/carreras">Carreras</a>
            <a href="/planes">Planes</a>
            <a href="/materias">Materias</a>
        </nav>

        <div class="glass-panel">
            <div class="header-flex">
                <h2>Lista de Materias</h2>
                <a href="/materias/new" class="btn btn-primary">+ Nueva Materia</a>
            </div>

            <table>
                <thead>
                    <tr>
                        <th>ID Materia</th>
                        <th>Código</th>
                        <th>Nombre</th>
                        <th>Período</th>
                        <th>ID Plan</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {{#materias}}
                    <tr>
                        <td>{{id_materia}}</td>
                        <td>{{codigo}}</td>
                        <td>{{nombre}}</td>
                        <td>{{periodo}}</td>
                        <td>{{id_plan}}</td>
                        <td class="actions">
                            <a href="/materias/{{id_materia}}/edit" class="btn btn-secondary">Editar</a>
                            <form action="/materias/{{id_materia}}/delete" method="POST" style="display:inline;">
                                <button type="submit" class="btn btn-danger" onclick="return confirm('¿Seguro que desea eliminar?');">Borrar</button>
                            </form>
                        </td>
                    </tr>
                    {{/materias}}
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>
