<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>{{#alumno}}Editar{{/alumno}}{{^alumno}}Nuevo{{/alumno}} Alumno</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <div class="container">
        <nav class="nav">
            <a href="/alumnos">← Volver a Alumnos</a>
        </nav>
        <div class="glass-panel">
            <h2>{{#alumno}}Editar{{/alumno}}{{^alumno}}Nuevo{{/alumno}} Alumno</h2>
            {{#error}}<div class="alert alert-error">{{error}}</div>{{/error}}
            <form action="{{#alumno}}/alumnos/{{legajo}}/edit{{/alumno}}{{^alumno}}/alumnos/new{{/alumno}}" method="POST">
                <div class="form-group">
                    <label>Legajo</label>
                    <input type="text" name="legajo" value="{{#alumno}}{{legajo}}{{/alumno}}" {{#alumno}}readonly{{/alumno}} required>
                </div>
                <div class="form-group">
                    <label>DNI</label>
                    <input type="text" name="dni" value="{{#persona}}{{dni}}{{/persona}}" {{#alumno}}readonly{{/alumno}} required>
                </div>
                <div class="form-group">
                    <label>Tipo Alumno</label>
                    <select name="tipo_alumno" required>
                        <option value="INGRESANTE" {{#alumno}}{{#tipo_alumno_ingresante}}selected{{/tipo_alumno_ingresante}}{{/alumno}}>INGRESANTE</option>
                        <option value="AVANZADO" {{#alumno}}{{#tipo_alumno_avanzado}}selected{{/tipo_alumno_avanzado}}{{/alumno}}>AVANZADO</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Nombre</label>
                    <input type="text" name="nombre" value="{{#persona}}{{nombre}}{{/persona}}" required>
                </div>
                <div class="form-group">
                    <label>Apellido</label>
                    <input type="text" name="apellido" value="{{#persona}}{{apellido}}{{/persona}}" required>
                </div>
                <div class="form-group">
                    <label>Correo Electrónico</label>
                    <input type="email" name="correo" value="{{#persona}}{{correo}}{{/persona}}" required>
                </div>
                <button type="submit" class="btn btn-primary">Guardar</button>
            </form>
        </div>
    </div>
</body>
</html>
