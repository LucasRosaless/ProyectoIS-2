<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>{{#materia}}Editar{{/materia}}{{^materia}}Nueva{{/materia}} Materia</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <div class="container">
        <nav class="nav">
            <a href="/materias">← Volver a Materias</a>
        </nav>
        <div class="glass-panel">
            <h2>{{#materia}}Editar{{/materia}}{{^materia}}Nueva{{/materia}} Materia</h2>
            {{#error}}<div class="alert alert-error">{{error}}</div>{{/error}}
            <form action="{{#materia}}/materias/{{id_materia}}/edit{{/materia}}{{^materia}}/materias/new{{/materia}}" method="POST">
                <div class="form-group">
                    <label>ID Materia</label>
                    <input type="number" name="id_materia" value="{{#materia}}{{id_materia}}{{/materia}}" {{#materia}}readonly{{/materia}} required>
                </div>
                <div class="form-group">
                    <label>Código</label>
                    <input type="text" name="codigo" value="{{#materia}}{{codigo}}{{/materia}}" required>
                </div>
                <div class="form-group">
                    <label>Nombre de la Materia</label>
                    <input type="text" name="nombre" value="{{#materia}}{{nombre}}{{/materia}}" required>
                </div>
                <div class="form-group">
                    <label>Período (ej. CUATRIMESTRAL, ANUAL)</label>
                    <select name="periodo" required>
                        <option value="CUATRIMESTRAL">CUATRIMESTRAL</option>
                        <option value="BIMESTRAL">BIMESTRAL</option>
                        <option value="ANUAL">ANUAL</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Plan de Estudio</label>
                    <select name="id_plan" required>
                        <option value="">Seleccione un plan de estudio...</option>
                        {{#planes}}
                        <option value="{{id_plan}}">Resolución: {{resolucion}} (ID: {{id_plan}})</option>
                        {{/planes}}
                    </select>
                </div>
                <button type="submit" class="btn btn-primary">Guardar</button>
            </form>
        </div>
    </div>
</body>
</html>
